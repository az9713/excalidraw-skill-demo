      "text": "{\n  \"channel\": \"#deploys\",\n  \"username\": \"CI/CD Bot\",\n  \"icon_emoji\": \":x:\",\n  \"blocks\": [{\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*Pipeline Failed*\\n\"\n        + \"Repo: myorg/myapp\\n\"\n        + \"Branch: main\\n\"\n        + \"Step: unit-tests\\n\"\n        + \"Author: @engineer\\n\"\n        + \"Commit: abc1234\\n\"\n        + \"<url|View Logs>\"\n    }\n  }]\n}",
